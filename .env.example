# ── Playwright (mobile browser — JobSafe web app) ─────────────────────────
BASE_URL=https://app.tst.jobsafe.cloud/login
USER_EMAIL=your@email.com
USER_PASSWORD=your-password

# ── MobileWright sample app (free APK, no JobSafe build needed) ───────────
# Run: npm run native:fetch-sample  then  npm run native:test:sample
# Needs: Android emulator + ANDROID_HOME (see npm run native:doctor)

# ── MobileWright JobSafe native (when you have APK/IPA) ───────────────────
# ANDROID_APK_PATH=C:\path\to\jobsafe.apk
# ANDROID_PACKAGE=com.yourcompany.jobsafe
# IOS_APP_PATH=C:\path\to\JobSafe.ipa
# IOS_BUNDLE_ID=com.yourcompany.jobsafe

# ── MobileWright cloud devices (optional, paid) ───────────────────────────
# https://mobile-use.com — real phones in the cloud
# MOBILE_USE_API_KEY=your-key
# MOBILE_USE_REGION=us
